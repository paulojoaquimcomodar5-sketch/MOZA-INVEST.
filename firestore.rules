rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // For this app, we check if the user is in an 'admins' collection or has a specific UID
      // Since it's a luxury app, we might have a hardcoded admin or look up
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Collections ---

    match /messages/{messageId} {
      allow read: if true; // Allow guests to see the community chat
      allow create: if isSignedIn() 
        && isValidId(messageId)
        && isValidMessage(incoming())
        && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'userId', 'userName', 'timestamp'])
        && data.keys().size() >= 4
        && data.text is string && data.text.size() <= 1000
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 100
        && data.timestamp is number;
    }

    match /configs/{configId} {
      allow read: if true; // App status might need to be read before login
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
