{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A community chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "timestamp": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "isAI": { "type": "boolean" }
      },
      "required": ["text", "userId", "userName", "timestamp"]
    },
    "AppConfig": {
      "title": "App Configuration",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["online", "offline"] },
        "message": { "type": "string" },
        "welcomeSettings": { "type": "object" },
        "validInviteCode": { "type": "string" },
        "paymentMethods": { "type": "array" }
      }
    },
    "User": {
      "title": "User",
      "description": "A registered user in the platform",
      "type": "object",
      "properties": {
        "phone": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "fundBalance": { "type": "number" },
        "totalProfit": { "type": "number" },
        "level": { "type": "string" },
        "status": { "type": "string" },
        "inviteCode": { "type": "string" },
        "upline": { "type": "string" },
        "tickets": { "type": "number" },
        "profileImage": { "type": "string" },
        "joinedAt": { "type": "string" }
      },
      "required": ["phone", "name", "balance"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of registered users"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of community chat messages"
    },
    "/configs/app_status": {
      "schema": "AppConfig",
      "description": "Global app status and settings"
    }
  }
}
